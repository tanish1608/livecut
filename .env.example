# Gemini / Vertex AI
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
LIVE_MODEL=gemini-3.1-flash-live-preview
LIVE_SYSTEM_INSTRUCTION=You are LiveCut, an autonomous broadcast producer that uses tools for OBS control.
LIVE_RESPONSE_MODALITIES=TEXT
GEMINI_SIMPLE_ASSISTANT_MODE=false
GEMINI_COMMAND_MODEL=gemini-2.5-flash
CHROME_LISTENER_HOST=127.0.0.1
CHROME_LISTENER_PORT=8765
CHROME_AUTO_OPEN=true
GEMINI_SPEAK_REPLIES=true
GEMINI_VOICE_ASSISTANT_MODE=false
GEMINI_REQUIRE_WAKE_WORD=true
GEMINI_VOICE_WAKE_WORD=gemini
GEMINI_WAKE_WINDOW_SECONDS=8
GEMINI_BOOTSTRAP_USER_TEXT=
GEMINI_KEEPALIVE_SECONDS=0
GEMINI_KEEPALIVE_TEXT=status
GEMINI_AUTO_RECONNECT=true
GEMINI_RECONNECT_BACKOFF_SECONDS=2
GEMINI_MAX_RECONNECT_BACKOFF_SECONDS=30
GEMINI_AUDIO_ENABLED=true
GEMINI_VIDEO_ENABLED=false
GEMINI_AUDIO_SAMPLE_RATE_HZ=16000
GEMINI_AUDIO_BLOCKSIZE_FRAMES=1024
GEMINI_AUDIO_INPUT_DEVICE=
GEMINI_AUDIO_OUTPUT_ENABLED=true
GEMINI_AUDIO_OUTPUT_DEVICE=
GEMINI_VIDEO_DEVICE_INDEX=0
GEMINI_VIDEO_SOURCE_MODE=obs_program_scene
GEMINI_VIDEO_SOURCE_NAME=
GEMINI_VIDEO_FPS=2.0
GEMINI_VIDEO_WIDTH=1280
GEMINI_VIDEO_HEIGHT=720
GEMINI_VIDEO_JPEG_QUALITY=70

# NVIDIA VLM (video-native)
ENABLE_VLM=false
VLM_MODEL=nvidia/nemotron-nano-12b-v2-vl
VLM_BASE_URL=https://integrate.api.nvidia.com
NVIDIA_API_KEY=
VLM_POLL_SECONDS=1.0
VLM_REQUEST_TIMEOUT_SECONDS=12
VLM_MAX_ACTIONS_PER_TURN=2
VLM_ALLOWED_TOOLS=switch_scene
VLM_ACTION_COOLDOWN_SECONDS=5.0
VLM_SCENE_SWITCH_DELAY_SECONDS=1.5
VLM_ERROR_BACKOFF_BASE_SECONDS=1.0
VLM_ERROR_BACKOFF_MAX_SECONDS=8.0
VLM_ROLE=director
VLM_ENABLE_TOOL_CALLS=false
VLM_KILL_DETECTION_ENABLED=true
VLM_KILL_KEYWORDS=eliminated,knocked,kill,frag,headshot
VLM_SYSTEM_INSTRUCTION=

# OBS
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=
SCENE_GAMEPLAY_FOCUS=Gameplay_Focus
SCENE_CHATTING_FOCUS=Chatting_Focus
INPUT_HOST_MIC=Host Mic
SOURCE_SFX_AIRHORN=SFX_Airhorn
SOURCE_LOWER_THIRD_TEXT=LowerThirdText
SOURCE_HOST_PROMPT_TEXT=HostPromptText
SOURCE_CHAT_QUESTION_TEXT=ChatQuestionText
SOURCE_BROLL_IMAGE=BrollImage

# LiveCut behavior
SEGMENT_MAX_MINUTES=20
CHAT_BATCH_SECONDS=60
RUN_SIMULATION_LOOPS_WITH_GEMINI=false
AI_ONLY_SCENE_SWITCHING=true
GEMINI_SCENE_SWITCH_DELAY_SECONDS=0.0
SCENE_MIN_DWELL_SECONDS=0.0
COUGH_RECOVERY_SECONDS=1.0
RUNTIME_STATUS_LOG_SECONDS=15
GEMINI_RECEIVE_IDLE_LOG_SECONDS=15
GEMINI_USE_VLM_CONTEXT=true
GEMINI_VLM_CONTEXT_MIN_INTERVAL_SECONDS=2.0
GEMINI_CHAT_ACTIONS_ONLY_IN_CHAT_SCENE=true
HOST_USERNAME=Tanish
ENABLE_GEMINI=false
